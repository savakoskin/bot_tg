# 1) Получить токен у @BotFather
TELEGRAM_BOT_TOKEN=put_telegram_bot_token_here

# 2) NASA API key: https://api.nasa.gov/
# Для теста можно оставить DEMO_KEY, но у него ниже лимиты.
NASA_API_KEY=DEMO_KEY

# Часовой пояс для вывода событий и ручного добавления /addevent
BOT_TIMEZONE=Europe/Moscow

# SQLite база
DB_PATH=space_astro_bot.sqlite3

# Файл с первичными событиями. На старте бот загрузит их в SQLite.
EVENT_SEED_PATH=data/events.example.json

# Кто может добавлять/удалять события через /addevent и /delevent.
# Если оставить пустым, админ-команды доступны всем — удобно для теста, плохо для продакшена.
# Узнать свой chat_id можно командой /myid.
ADMIN_CHAT_IDS=

# Дополнительные RSS-источники. Формат:
# EXTRA_RSS_SOURCES=Название|https://site.com/feed.xml;Другое название|https://site.com/rss
EXTRA_RSS_SOURCES=

NEWS_CHECK_INTERVAL_SECONDS=1800
PHOTO_CHECK_INTERVAL_SECONDS=21600
EVENT_CHECK_INTERVAL_SECONDS=1800
NEWS_MAX_PER_RUN=5
